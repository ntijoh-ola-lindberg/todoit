<section>
    <h1>Uppdatera todo</h1>
    <form action="/todos/<%= @todo['id'] %>/update" method="post">
        <article class="update_todo">

            <label>Titel <input type="text" name="todo_title" value="<%= @todo['todo_title'] %>"></label>
            <label>Beskrivning <input type="text" name="todo_description" value="<%= @todo['todo_description'] %>"></label>

            <label>Färdig:
                <% if @todo['is_completed'] == 1 %>
                        <input name="is_completed" type="checkbox" checked />
                <% else %>
                        <input name="is_completed" type="checkbox" />
                <% end %>
            </label>

            <label>Kategori:
              <select name="category_id" id="categories-select">
                <% @categories.each do |c| %>
                  <option value="<%= c['id'] %>" <%= 'selected' if c['id'] == @todo['category_id'] %>>
                    <%= c['category_title'] %>
                  </option>
                <% end %>
              </select>
            </label>

            <input type="submit" value="Uppdatera">
        </article>
    </form>

</section>
