<section>
        <h1>Alla kategorier</h1>
        <article class="categories">
                <ul class="categories">
                <% @categories.each do | c | %>
                        <li>
                          <%=c['category_title']%>

                          <form action="/categories/<%= c['id']%>/delete" method="post">
                            <input type="submit" value="Ta bort">
                          </form>

                          <a href="/categories/<%=c['id']%>/edit" class="button">Ändra</a>
                        </li>
                <% end %>
                </ul>
        </article>
</section>
<section>
        <h1>Ny kategori</h1>
        <article class="new-category">
                <form action="/categories/new" method="post">
                <label>Namn på kategori <input type="text" name="category_title" /></label>
                <input type="submit" value="Färdig">
                </form>
        </article>
</section>